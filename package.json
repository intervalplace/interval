{
  "name": "interval",
  "version": "0.80.0",
  "description": "A world that runs on rules, not servers. Decentralized deterministic MMO protocol.",
  "scripts": {
    "test": "npm run test:unit && npm run test:adversarial:ci",
    "play": "node play.mjs",
    "serve": "node serve.mjs",
    "demo:network": "node demo.mjs",
    "demo:join": "node demo2.mjs",
    "demo:trade": "node demo3.mjs",
    "demo:clock": "node demo4.mjs",
    "demo:stall": "node demo5.mjs",
    "demo6": "node demo6.mjs",
    "sim": "node sim.js",
    "advsim": "node advsim.mjs all 3 30000",
    "demo7": "node demo7.mjs",
    "e2e": "bash e2e-multiproc.sh",
    "demo:adversarial": "node demo7.mjs",
    "sdk-test": "node --test test/sdk.test.mjs",
    "evidence": "bash freeze-evidence.sh",
    "test:unit": "node run-tests.mjs",
    "test:adversarial:ci": "node run-tests.mjs --only adversarial",
    "test:adversarial:full": "node advsim.mjs all 3 30000",
    "storage:health": "node storage-ops.mjs health",
    "storage:backup": "node storage-ops.mjs backup",
    "storage:verify": "node storage-ops.mjs verify",
    "bench:storage": "node bench-storage.mjs",
    "manifest": "node manifest.mjs",
    "manifest:check": "node manifest.mjs --check",
    "test:all": "node run-tests.mjs --all"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@chainsafe/libp2p-noise": "^16.1.5",
    "@chainsafe/libp2p-yamux": "^7.0.4",
    "@libp2p/identify": "^3.0.39",
    "@libp2p/tcp": "^10.1.19",
    "@multiformats/multiaddr": "^12.5.1",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "libp2p": "^2.10.0",
    "ws": "^8.21.1"
  },
  "type": "commonjs",
  "release": "phase-1-freeze",
  "protocol": {
    "specVersion": "0.80",
    "consensusVersion": "1.9",
    "rulesHash": "9fa16a8d52d920eb"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
